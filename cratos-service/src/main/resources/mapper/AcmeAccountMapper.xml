<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.baiyi.cratos.mapper.AcmeAccountMapper">
    <resultMap id="BaseResultMap" type="com.baiyi.cratos.domain.generator.AcmeAccount">
        <!--
          WARNING - @mbg.generated
        -->
        <id column="id" jdbcType="INTEGER" property="id"/>
        <result column="name" jdbcType="VARCHAR" property="name"/>
        <result column="email" jdbcType="VARCHAR" property="email"/>
        <result column="acme_provider" jdbcType="VARCHAR" property="acmeProvider"/>
        <result column="account_url" jdbcType="VARCHAR" property="accountUrl"/>
        <result column="acme_server" jdbcType="VARCHAR" property="acmeServer"/>
        <result column="account_key_pair" jdbcType="LONGVARCHAR" property="accountKeyPair"/>
        <result column="eab_kid " jdbcType="VARCHAR" property="eabKid"/>
        <result column="eab_hmac_key" jdbcType="LONGVARCHAR" property="eabHmacKey"/>
        <result column="created_by" jdbcType="VARCHAR" property="createdBy"/>
        <result column="valid" jdbcType="BIT" property="valid"/>
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
        <result column="update_time" jdbcType="TIMESTAMP" property="updateTime"/>
    </resultMap>

    <select id="queryPageByParam"
            parameterType="com.baiyi.cratos.domain.param.http.acme.AcmeAccountParam$AccountPageQuery"
            resultMap="BaseResultMap">
        select * from acme_account
        <where>
            <if test="valid != null">
                and valid = #{valid}
            </if>
            <if test="queryName != null and queryName != ''">
                and name like "%" #{queryName} "%"
                order by replace(name, #{queryName}, '')
            </if>
        </where>
    </select>

</mapper>